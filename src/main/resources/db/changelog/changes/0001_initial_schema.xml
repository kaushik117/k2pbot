            </column>
            <column name="route_name" type="varchar(100)"/>
            <column name="route_type" type="varchar(32)"/>
            <column name="min_prompt_length" type="int"/>
            <column name="max_prompt_length" type="int"/>
            <column name="rag_enabled_only" type="boolean"/>
            <column name="tools_required_only" type="boolean"/>
            <column name="structured_output_only" type="boolean"/>
            <column name="target_provider" type="varchar(100)"/>
            <column name="target_model" type="varchar(100)"/>
            <column name="max_input_tokens" type="int"/>
            <column name="temperature" type="double"/>
            <column name="priority" type="int"/>
