<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="0001-1-create-ai_assistant" author="chatbot-platform">
        <createTable tableName="ai_assistant">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="assistant_code" type="varchar(100)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_ai_assistant_code"/>
            </column>
            <column name="name" type="varchar(256)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="varchar(1024)"/>
            <column name="tenant_scope" type="varchar(100)"/>
            <column name="config_version" type="varchar(50)"/>
            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="varchar(100)"/>
            <column name="updated_by" type="varchar(100)"/>
            <column name="row_version" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="0001-2-create-ai_assistant_prompt" author="chatbot-platform">
        <createTable tableName="ai_assistant_prompt">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="assistant_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_ai_prompt_assistant"
                             referencedTableName="ai_assistant"
                             referencedColumnNames="id"/>
            </column>
            <column name="version" type="varchar(50)"/>
            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="system_prompt_template" type="clob"/>
            <column name="developer_prompt_template" type="clob"/>
            <column name="prompt_variables" type="clob"/>
            <column name="guardrail_instructions" type="clob"/>
            <column name="created_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="varchar(100)"/>
            <column name="updated_by" type="varchar(100)"/>
            <column name="row_version" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="ai_assistant_prompt" indexName="idx_ai_assistant_prompt_assistant">
            <column name="assistant_id"/>
        </createIndex>
    </changeSet>

