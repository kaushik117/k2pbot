        </createTable>
        <createIndex tableName="ai_assistant_model_route" indexName="idx_ai_model_route_assistant">
            <column name="assistant_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="0001-4-create-ai_assistant_memory_policy" author="chatbot-platform">
